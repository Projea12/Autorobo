<mujoco model="tidybot_ar">
  <compiler angle="radian" meshdir="assets"/>

  <asset>
    <texture type="skybox" builtin="flat" rgb1=".12 .12 .12" rgb2=".12 .12 .12"
             width="512" height="512"/>
  </asset>

  <visual>
    <global offwidth="1280" offheight="1280"/>
    <headlight diffuse="0.8 0.8 0.8" ambient="0.4 0.4 0.4" specular="0.2 0.2 0.2"/>
    <rgba haze="0.15 0.15 0.15 1"/>
    <quality shadowsize="2048"/>
  </visual>

  <include file="tidybot.xml"/>

  <worldbody>
    <!-- Directional lights — illuminate everywhere regardless of robot position -->
    <light name="key" directional="true" dir="0.3 0.6 -1"
           diffuse="0.7 0.68 0.62" specular="0.2 0.2 0.2" castshadow="false"/>
    <light name="fill" directional="true" dir="-0.5 -0.3 -1"
           diffuse="0.35 0.38 0.42" specular="0.05 0.05 0.05" castshadow="false"/>
    <light name="rim" directional="true" dir="0 -1 -0.3"
           diffuse="0.25 0.25 0.3" specular="0.02 0.02 0.02" castshadow="false"/>

    <!-- Target object — repositioned to click xyz before each grasp -->
    <body name="target_object" pos="0 0.5 0.45">
      <geom name="target_geom" type="cylinder" size="0.035 0.055"
            rgba="0.9 0.35 0.1 1" mass="0.15" contype="1" conaffinity="1"/>
    </body>

    <!-- Table surface under the target object -->
    <geom name="table_surface" type="box" size="0.4 0.4 0.01"
          pos="0 0.5 0.38" rgba="0.55 0.4 0.25 1"
          contype="1" conaffinity="1"/>
  </worldbody>
</mujoco>

<?xml version="1.0"?>
<robot name="nav_robot">

  <!-- ═══════════════════════════════════════════
       MATERIALS
  ═══════════════════════════════════════════ -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.1 0.4 0.8 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="rubber">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>

  <!-- ═══════════════════════════════════════════
       BASE FOOTPRINT
       Ground-plane reference frame (z = 0 = floor).
       base_link sits wheel-radius (0.05 m) above this.
  ═══════════════════════════════════════════ -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════
       BASE LINK (chassis)

       Dimensions : 0.40 m (L) × 0.30 m (W) × 0.10 m (H)
       Mass       : 5.0 kg   (aluminium frame + PCBs + battery)
       CoM        : geometric centre of the box

       Inertia tensor for a solid box  I = m/12 * (a²+b²)
         Ixx = 5/12 * (0.30²+0.10²) = 0.04167  kg·m²
         Iyy = 5/12 * (0.40²+0.10²) = 0.07083  kg·m²
         Izz = 5/12 * (0.40²+0.30²) = 0.10417  kg·m²
  ═══════════════════════════════════════════ -->
  <link name="base_link">

    <!-- INERTIAL ─ centre of mass at box centroid -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.04167" ixy="0.0" ixz="0.0"
               iyy="0.07083" iyz="0.0"
               izz="0.10417"/>
    </inertial>

    <!-- VISUAL 1: mesh (preferred when file exists) -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Replace with: <mesh filename="package://robot_nav_ai/robot/meshes/chassis.stl" scale="1 1 1"/> -->
        <box size="0.40 0.30 0.10"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>

    <!-- VISUAL 2: top deck plate -->
    <visual>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <box size="0.36 0.26 0.01"/>
      </geometry>
      <material name="light_grey"/>
    </visual>

    <!-- VISUAL 3: front bumper bar -->
    <visual>
      <origin xyz="0.21 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.30 0.06"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <!-- VISUAL 4: rear bumper bar -->
    <visual>
      <origin xyz="-0.21 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.30 0.06"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <!-- COLLISION: single convex hull matches outer box -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.40 0.30 0.10"/>
      </geometry>
    </collision>

  </link>

  <!-- ═══════════════════════════════════════════
       LEFT DRIVE WHEEL

       Geometry   : cylinder  r=0.05 m  width=0.04 m
       Mass       : 0.5 kg  (rubber tyre + aluminium hub)
       Spin axis  : Y  →  Iyy is the "easy" spin inertia

       Inertia for solid cylinder, axis along Y:
         Iyy = ½·m·r²          = 0.5·0.5·0.0025  = 0.000625  kg·m²
         Ixx = Izz = m/12·(3r²+l²) = 0.5/12·(0.0075+0.0016) = 0.000379  kg·m²

       Placement  : x= 0.0  (wheel axle at chassis midpoint)
                    y=+0.17 m  (chassis half-width 0.15 + wheel half-width 0.02)
                    z= 0.0  (wheel centre at chassis mid-height)
  ═══════════════════════════════════════════ -->
  <link name="left_wheel">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000379" ixy="0.0" ixz="0.0"
               iyy="0.000625" iyz="0.0"
               izz="0.000379"/>
    </inertial>

    <!-- VISUAL 1: rubber tyre (outer ring) -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
      <material name="rubber"/>
    </visual>

    <!-- VISUAL 2: aluminium hub (inner disc) -->
    <visual>
      <origin xyz="0 0.021 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.003"/>
      </geometry>
      <material name="silver"/>
    </visual>

    <!-- VISUAL 3: hub bolt circle (decorative cross) -->
    <visual>
      <origin xyz="0 0.022 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.008 0.003 0.040"/>
      </geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="0 0.022 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.040 0.003 0.008"/>
      </geometry>
      <material name="black"/>
    </visual>

    <!-- COLLISION: single cylinder — keeps physics stable -->
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
    </collision>

  </link>

  <!-- continuous joint — no position limit, motor drives velocity -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.0 0.17 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="10.0"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <!-- ═══════════════════════════════════════════
       RIGHT DRIVE WHEEL  (mirror of left)

       Geometry / mass / inertia identical to left wheel.
       Placement  : y = −0.17 m  (opposite side)
                    hub face points outward at y = −0.021
  ═══════════════════════════════════════════ -->
  <link name="right_wheel">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000379" ixy="0.0" ixz="0.0"
               iyy="0.000625" iyz="0.0"
               izz="0.000379"/>
    </inertial>

    <!-- VISUAL 1: rubber tyre -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
      <material name="rubber"/>
    </visual>

    <!-- VISUAL 2: aluminium hub (faces outward → negative Y) -->
    <visual>
      <origin xyz="0 -0.021 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.003"/>
      </geometry>
      <material name="silver"/>
    </visual>

    <!-- VISUAL 3: hub bolt circle -->
    <visual>
      <origin xyz="0 -0.022 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.008 0.003 0.040"/>
      </geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="0 -0.022 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.040 0.003 0.008"/>
      </geometry>
      <material name="black"/>
    </visual>

    <!-- COLLISION -->
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
    </collision>

  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.17 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="10.0"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <!-- ═══════════════════════════════════════════
       CASTER WHEEL (passive, rear)
  ═══════════════════════════════════════════ -->
  <link name="caster_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="-0.15 0.0 -0.02" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════
       LIDAR SENSOR (top mount)
  ═══════════════════════════════════════════ -->
  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.05 0.0 0.12" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════
       CAMERA SENSOR (front mount)
  ═══════════════════════════════════════════ -->
  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0"
               iyy="0.00005" iyz="0.0"
               izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.06 0.03"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.06 0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.21 0.0 0.07" rpy="0 0 0"/>
  </joint>

  <!-- Camera optical frame (Z forward, X right, Y down — ROS convention) -->
  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ═══════════════════════════════════════════
       IMU SENSOR (chassis centre)
  ═══════════════════════════════════════════ -->
  <link name="imu_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0"
               izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0.0 0.05" rpy="0 0 0"/>
  </joint>

</robot>
